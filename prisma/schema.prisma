generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  locale       String   @default("ru")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facebookConnection FacebookConnection?
  telegramConnection TelegramConnection?
  facebookPages      FacebookPage[]
  leads              Lead[]
  deliveryLogs       DeliveryLog[]
  webhookEvents      WebhookEvent[]
  auditLogs          AuditLog[]
  systemLogs         SystemLog[]
  webhookVerificationLogs WebhookVerificationLog[]
  passwordResetTokens PasswordResetToken[]
  integrationSettings IntegrationSettings?

  @@map("users")
}

model IntegrationSettings {
  id                              String   @id @default(cuid())
  userId                          String   @unique
  metaAppId                       String?
  metaAppSecretEncrypted          String?  @db.Text
  metaWebhookVerifyTokenEncrypted String?  @db.Text
  metaWebhookVerifyTokenHash      String?  @unique
  configured                      Boolean  @default(false)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("integration_settings")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model FacebookConnection {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  accessTokenEncrypted   String    @db.Text
  tokenExpiresAt         DateTime?
  facebookUserId         String?
  facebookUserName       String?
  facebookUserPictureUrl String?
  metaAppIdAtAuth        String?
  status                 String    @default("connected")
  connectedAt            DateTime?
  lastCheckedAt          DateTime?
  lastError              String?
  lastErrorCode          String?
  lastErrorAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("facebook_connections")
}

model FacebookPage {
  id                        String    @id @default(cuid())
  userId                    String
  pageId                    String
  pageName                  String
  pageAccessTokenEncrypted  String    @db.Text
  tokenExpiresAt            DateTime?
  connected                 Boolean   @default(false)
  syncStatus                String    @default("pending")
  webhookStatus             String    @default("pending")
  lastError                 String?
  lastErrorAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  forms FacebookForm[]

  @@unique([userId, pageId])
  @@index([pageId])
  @@map("facebook_pages")
}

model FacebookForm {
  id            String    @id @default(cuid())
  pageId        String
  formId        String
  formName      String
  enabled       Boolean   @default(false)
  status        String    @default("active")
  syncStatus    String    @default("pending")
  lastSyncError String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  page  FacebookPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@unique([pageId, formId])
  @@map("facebook_forms")
}

model TelegramConnection {
  id                 String    @id @default(cuid())
  userId             String    @unique
  botTokenEncrypted  String    @db.Text
  chatId             String
  notificationLocale String    @default("ru")
  verified           Boolean   @default(false)
  status             String    @default("disconnected")
  lastError          String?
  lastErrorAt        DateTime?
  lastCheckedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_connections")
}

model Lead {
  id          String   @id @default(cuid())
  userId      String
  formId      String?
  leadgenId   String
  name        String?
  phone       String?
  email       String?
  fieldData   Json     @default("{}")
  rawData     Json     @default("{}")
  status      String   @default("new")
  createdTime DateTime
  importedAt  DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  form         FacebookForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  deliveryLogs DeliveryLog[]

  @@unique([userId, leadgenId])
  @@index([userId, createdTime])
  @@index([userId, status])
  @@map("leads")
}

model DeliveryLog {
  id           String   @id @default(cuid())
  leadId       String?
  userId       String
  type         String
  status       String   @default("pending")
  retryCount   Int      @default(0)
  retryHistory Json     @default("[]")
  errorMessage String?
  lastErrorCode String?
  lastErrorAt  DateTime?
  message      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@map("delivery_logs")
}

model WebhookEvent {
  id            String    @id @default(cuid())
  userId        String?
  eventType     String
  payload       Json
  status        String    @default("received")
  pageId        String?
  formId        String?
  leadgenId     String?
  lastError     String?
  lastErrorCode String?
  lastErrorAt   DateTime?
  sourceIp      String?
  userAgent     String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([leadgenId])
  @@map("webhook_events")
}

model WebhookVerificationLog {
  id               String   @id @default(cuid())
  userId           String?
  mode             String?
  tokenMasked      String?
  challengePresent Boolean  @default(false)
  success          Boolean  @default(false)
  ipAddress        String?
  userAgent        String?
  errorMessage     String?
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([success, createdAt])
  @@map("webhook_verification_logs")
}

model SystemLog {
  id        String   @id @default(cuid())
  userId    String?
  level     String   @default("info")
  source    String
  action    String
  message   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([source, level, createdAt])
  @@map("system_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("audit_logs")
}
