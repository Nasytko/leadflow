generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  locale       String   @default("ru")
  auditPreferences Json @default("{}")
  status       String   @default("pending_email_verification")
  isAdmin      Boolean  @default(false)
  emailVerifiedAt DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facebookConnection FacebookConnection?
  telegramConnection TelegramConnection?
  facebookBusinesses   FacebookBusiness[]
  facebookPages      FacebookPage[]
  metaAdAccounts     MetaAdAccount[]
  metaCampaigns      MetaCampaign[]
  metaAdSets         MetaAdSet[]
  metaAds            MetaAd[]
  metaInsightSnapshots MetaInsightSnapshot[]
  leads              Lead[]
  deliveryLogs       DeliveryLog[]
  webhookEvents      WebhookEvent[]
  auditLogs          AuditLog[]
  systemLogs         SystemLog[]
  webhookVerificationLogs WebhookVerificationLog[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  integrationSettings IntegrationSettings?
  processedLeads          Lead[]                   @relation("ProcessedLeads")
  adminDiagnosticRuns     AdminDiagnosticRun[]

  @@map("users")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model InviteCode {
  id           String   @id @default(cuid())
  codeHash     String   @unique
  createdById  String?
  usedById     String?
  usedAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([usedById])
  @@map("invite_codes")
}

model IntegrationSettings {
  id                              String   @id @default(cuid())
  userId                          String   @unique
  metaAppId                       String?
  metaAppSecretEncrypted          String?  @db.Text
  metaWebhookVerifyTokenEncrypted String?  @db.Text
  metaWebhookVerifyTokenHash      String?  @unique
  metaLoginConfigId               String?
  configured                      Boolean  @default(false)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("integration_settings")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model FacebookConnection {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  accessTokenEncrypted   String    @db.Text
  tokenExpiresAt         DateTime?
  facebookUserId         String?
  facebookUserName       String?
  facebookUserPictureUrl String?
  metaAppIdAtAuth        String?
  metaLoginConfigIdAtAuth String?
  grantedScopes          Json      @default("[]")
  granularScopes         Json      @default("[]")
  pagesCountAtAuth       Int?
  businessIds            Json      @default("[]")
  primaryBusinessId      String?
  status                 String    @default("connected")
  connectedAt            DateTime?
  lastCheckedAt          DateTime?
  lastError              String?
  lastErrorCode          String?
  lastErrorAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccounts MetaAdAccount[]

  @@map("facebook_connections")
}

model FacebookBusiness {
  id                 String   @id @default(cuid())
  userId             String
  businessId         String
  name               String
  verificationStatus String?
  pictureUrl         String?
  link               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages FacebookPage[]
  adAccounts MetaAdAccount[]
  leads    Lead[]

  @@unique([userId, businessId])
  @@index([userId])
  @@map("facebook_businesses")
}

model FacebookPage {
  id                        String    @id @default(cuid())
  userId                    String
  pageId                    String
  pageName                  String
  pictureUrl                String?
  category                  String?
  link                      String?
  about                     String?   @db.Text
  tasks                     Json      @default("[]")
  businessId                String?
  pageAccessTokenEncrypted  String    @db.Text
  tokenExpiresAt            DateTime?
  connected                 Boolean   @default(false)
  syncStatus                String    @default("pending")
  webhookStatus             String    @default("pending")
  webhookSubscribedAt       DateTime?
  lastSyncedAt              DateTime?
  lastError                 String?
  lastErrorAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  business FacebookBusiness? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  forms    FacebookForm[]
  leads    Lead[]

  @@unique([userId, pageId])
  @@index([pageId])
  @@index([businessId])
  @@map("facebook_pages")
}

model FacebookForm {
  id            String    @id @default(cuid())
  pageId        String
  formId        String
  formName      String
  enabled       Boolean   @default(false)
  status        String    @default("active")
  metaCreatedAt DateTime?
  syncStatus    String    @default("pending")
  lastSyncError String?
  lastSyncAt    DateTime?
  leadCount     Int       @default(0)
  lastLeadAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  page  FacebookPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  leads Lead[]

  @@unique([pageId, formId])
  @@map("facebook_forms")
}

/// Meta Ad Account — per-user advertising account from /me/adaccounts
model MetaAdAccount {
  id              String    @id @default(cuid())
  userId          String
  connectionId    String
  businessDbId    String?
  metaAdAccountId String
  name            String
  accountStatus   Int?
  currency        String?
  timezoneName    String?
  businessName    String?
  amountSpent     String?
  balance         String?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection FacebookConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  business   FacebookBusiness?  @relation(fields: [businessDbId], references: [id], onDelete: SetNull)
  campaigns  MetaCampaign[]
  adSets     MetaAdSet[]
  ads        MetaAd[]
  insights   MetaInsightSnapshot[]
  leads      Lead[]

  @@unique([userId, metaAdAccountId])
  @@index([userId])
  @@index([connectionId])
  @@map("meta_ad_accounts")
}

model MetaCampaign {
  id              String    @id @default(cuid())
  userId          String
  adAccountDbId   String
  metaCampaignId  String
  name            String
  objective       String?
  status          String?
  effectiveStatus String?
  createdTime     DateTime?
  updatedTime     DateTime?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccount MetaAdAccount   @relation(fields: [adAccountDbId], references: [id], onDelete: Cascade)
  adSets    MetaAdSet[]
  ads       MetaAd[]
  insights  MetaInsightSnapshot[]
  leads     Lead[]

  @@unique([adAccountDbId, metaCampaignId])
  @@index([userId])
  @@map("meta_campaigns")
}

model MetaAdSet {
  id               String    @id @default(cuid())
  userId           String
  adAccountDbId    String
  campaignDbId     String?
  metaAdSetId      String
  name             String
  status           String?
  effectiveStatus  String?
  optimizationGoal String?
  billingEvent     String?
  createdTime      DateTime?
  updatedTime      DateTime?
  lastSyncedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccount MetaAdAccount @relation(fields: [adAccountDbId], references: [id], onDelete: Cascade)
  campaign  MetaCampaign? @relation(fields: [campaignDbId], references: [id], onDelete: SetNull)
  ads       MetaAd[]
  insights  MetaInsightSnapshot[]
  leads     Lead[]

  @@unique([adAccountDbId, metaAdSetId])
  @@index([userId])
  @@map("meta_ad_sets")
}

model MetaAd {
  id              String    @id @default(cuid())
  userId          String
  adAccountDbId   String
  campaignDbId    String?
  adSetDbId       String?
  metaAdId        String
  name            String
  status          String?
  effectiveStatus String?
  creativeId      String?
  createdTime     DateTime?
  updatedTime     DateTime?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccount MetaAdAccount @relation(fields: [adAccountDbId], references: [id], onDelete: Cascade)
  campaign  MetaCampaign? @relation(fields: [campaignDbId], references: [id], onDelete: SetNull)
  adSet     MetaAdSet?    @relation(fields: [adSetDbId], references: [id], onDelete: SetNull)
  insights  MetaInsightSnapshot[]
  leads     Lead[]

  @@unique([adAccountDbId, metaAdId])
  @@index([userId])
  @@map("meta_ads")
}

model MetaInsightSnapshot {
  id            String   @id @default(cuid())
  userId        String
  adAccountDbId String
  campaignDbId  String?
  adSetDbId     String?
  adDbId        String?
  dateStart     DateTime
  dateStop      DateTime
  spend         Float    @default(0)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  clicks        Int      @default(0)
  cpm           Float?
  cpc           Float?
  ctr           Float?
  leads         Int      @default(0)
  cpl           Float?
  createdAt     DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccount MetaAdAccount @relation(fields: [adAccountDbId], references: [id], onDelete: Cascade)
  campaign  MetaCampaign? @relation(fields: [campaignDbId], references: [id], onDelete: SetNull)
  adSet     MetaAdSet?    @relation(fields: [adSetDbId], references: [id], onDelete: SetNull)
  ad        MetaAd?       @relation(fields: [adDbId], references: [id], onDelete: SetNull)

  @@index([userId, adAccountDbId, dateStart])
  @@index([campaignDbId])
  @@map("meta_insight_snapshots")
}

model TelegramConnection {
  id                 String    @id @default(cuid())
  userId             String    @unique
  botTokenEncrypted  String    @db.Text
  chatId             String
  notificationLocale String    @default("ru")
  messageTemplateSettings Json @default("{}")
  verified           Boolean   @default(false)
  status             String    @default("disconnected")
  lastError          String?
  lastErrorAt        DateTime?
  lastCheckedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_connections")
}

model Lead {
  id          String   @id @default(cuid())
  userId      String
  formId      String?
  leadgenId   String
  name        String?
  phone       String?
  email       String?
  fieldData   Json     @default("{}")
  rawData     Json     @default("{}")
  status      String   @default("new")
  crmStatus   String   @default("new")
  telegramStatus String @default("not_sent")
  source      String   @default("webhook")
  managerNote String?  @db.Text
  campaignId   String?
  campaignName String?
  adsetId      String?
  adsetName   String?
  adId         String?
  adName      String?
  adAccountDbId String?
  campaignDbId  String?
  adSetDbId     String?
  adDbId        String?
  pageDbId      String?
  businessDbId  String?
  processedAt  DateTime?
  processedById String?
  createdTime DateTime
  importedAt  DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  form         FacebookForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  adAccount    MetaAdAccount? @relation(fields: [adAccountDbId], references: [id], onDelete: SetNull)
  campaign     MetaCampaign? @relation(fields: [campaignDbId], references: [id], onDelete: SetNull)
  adSet        MetaAdSet? @relation(fields: [adSetDbId], references: [id], onDelete: SetNull)
  ad           MetaAd? @relation(fields: [adDbId], references: [id], onDelete: SetNull)
  page         FacebookPage? @relation(fields: [pageDbId], references: [id], onDelete: SetNull)
  business     FacebookBusiness? @relation(fields: [businessDbId], references: [id], onDelete: SetNull)
  processedBy  User?         @relation("ProcessedLeads", fields: [processedById], references: [id], onDelete: SetNull)
  deliveryLogs DeliveryLog[]

  @@unique([userId, leadgenId])
  @@index([userId, createdTime])
  @@index([userId, status])
  @@index([userId, crmStatus])
  @@index([userId, telegramStatus])
  @@map("leads")
}

model DeliveryLog {
  id           String   @id @default(cuid())
  leadId       String?
  userId       String
  type         String
  status       String   @default("pending")
  retryCount   Int      @default(0)
  retryHistory Json     @default("[]")
  errorMessage String?
  lastErrorCode String?
  lastErrorAt  DateTime?
  message      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@index([leadId, status])
  @@map("delivery_logs")
}

model WebhookEvent {
  id            String    @id @default(cuid())
  userId        String?
  eventType     String
  payload       Json
  status        String    @default("received")
  pageId        String?
  formId        String?
  leadgenId     String?
  lastError     String?
  lastErrorCode String?
  lastErrorAt   DateTime?
  sourceIp      String?
  userAgent     String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([leadgenId])
  @@map("webhook_events")
}

model WebhookVerificationLog {
  id               String   @id @default(cuid())
  userId           String?
  mode             String?
  tokenMasked      String?
  challengePresent Boolean  @default(false)
  success          Boolean  @default(false)
  ipAddress        String?
  userAgent        String?
  errorMessage     String?
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([success, createdAt])
  @@map("webhook_verification_logs")
}

model SystemLog {
  id        String   @id @default(cuid())
  userId    String?
  level     String   @default("info")
  source    String
  action    String
  message   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([source, level, createdAt])
  @@map("system_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String?
  metadata  Json     @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("audit_logs")
}

model PlatformEmailSettings {
  id                    String    @id @default("platform")
  provider              String    @default("smtp")
  smtpHost              String?
  smtpPort              Int?
  smtpSecure            Boolean   @default(false)
  smtpUsername          String?
  smtpPasswordEncrypted String?   @db.Text
  fromName              String?
  fromEmail             String?
  replyToEmail          String?
  enabled               Boolean   @default(false)
  lastSentAt            DateTime?
  lastError             String?
  lastErrorAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("platform_email_settings")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

model AdminDiagnosticRun {
  id                String   @id @default(cuid())
  triggeredByUserId String?
  status            String
  summary           Json     @default("{}")
  checks            Json     @default("[]")
  createdAt         DateTime @default(now())

  triggeredBy User? @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("admin_diagnostic_runs")
}
