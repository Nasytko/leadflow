# Database (PostgreSQL 16+)
DATABASE_URL="postgresql://leadflow:leadflow@localhost:5432/leadflow?schema=public"

# Redis 7+ (required for queue, rate limiting, OAuth state)
REDIS_URL="redis://localhost:6379"

# NextAuth
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-with-openssl"
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# Encryption — 32 bytes as 64 hex characters (must match on web + worker)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Meta / Facebook (optional platform defaults; users can configure per-account in UI)
META_APP_ID=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""
# Require X-Hub-Signature-256 on POST /api/webhooks/meta (default: true in production)
META_WEBHOOK_SIGNATURE_REQUIRED=""
FACEBOOK_REDIRECT_URI=""

# Auth / registration hardening
REGISTRATION_MODE="open" # open | invite_only | approval_required

# Email (SMTP) for verification & password reset (required in production)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ORVIX <no-reply@your-domain.com>"

# Cloudflare Turnstile (optional)
TURNSTILE_ENABLED="false"
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Frontend site key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Facebook Login for Business — numeric Configuration ID from Meta App Dashboard
# (Facebook Login for Business → Configurations). Required for Business Manager page access.
# Example: META_LOGIN_CONFIG_ID=1045043297861606
# When set and valid, OAuth URL includes config_id=…; otherwise standard OAuth scopes are used.
# Alias: FACEBOOK_LOGIN_CONFIG_ID
META_LOGIN_CONFIG_ID=""
FACEBOOK_LOGIN_CONFIG_ID=""

# Environment
NODE_ENV="development"

# Deployment: saas (platform Meta App) | self_hosted (users configure own Meta App)
DEPLOYMENT_MODE="saas"
# SHOW_ADVANCED_META_SETTINGS="false"
