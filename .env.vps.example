# LeadFlow — production env template (VPS)
#
# Domain: https://fb.nasytko.ru
# Deploy: docker compose up -d --build
#
# IMPORTANT:
# - Do NOT commit your real .env
# - ENCRYPTION_KEY must be identical for web + worker

DATABASE_URL=postgresql://leadflow:leadflow@postgres:5432/leadflow?schema=public
REDIS_URL=redis://redis:6379

NEXTAUTH_URL=https://fb.nasytko.ru
NEXTAUTH_SECRET=GENERATE_WITH_OPENSSL

ENCRYPTION_KEY=GENERATE_64_HEX

META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

FACEBOOK_REDIRECT_URI=https://fb.nasytko.ru/api/facebook/callback

# Facebook Login for Business Configuration ID (numeric, from Meta App Dashboard)
# OAuth uses config_id when set; omit for standard Facebook Login fallback.
# Example: META_LOGIN_CONFIG_ID=1045043297861606
META_LOGIN_CONFIG_ID=

NODE_ENV=production

