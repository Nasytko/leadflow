# LeadFlow — production env template (VPS)
#
# Deploy: docker compose -f docker-compose.production.yml up -d --build
#
# IMPORTANT:
# - Do NOT commit your real .env
# - ENCRYPTION_KEY must be identical for web + worker
# - POSTGRES_* and REDIS_PASSWORD are required by docker-compose.production.yml

POSTGRES_USER=leadflow
POSTGRES_PASSWORD=GENERATE_STRONG_PASSWORD
POSTGRES_DB=leadflow

REDIS_PASSWORD=GENERATE_STRONG_PASSWORD

DATABASE_URL=postgresql://leadflow:GENERATE_STRONG_PASSWORD@postgres:5432/leadflow?schema=public
REDIS_URL=redis://:GENERATE_STRONG_PASSWORD@redis:6379

NEXTAUTH_URL=https://your-domain.example
NEXTAUTH_SECRET=GENERATE_WITH_OPENSSL

ENCRYPTION_KEY=GENERATE_64_HEX

META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

FACEBOOK_REDIRECT_URI=https://your-domain.example/api/facebook/callback

META_LOGIN_CONFIG_ID=

NODE_ENV=production
